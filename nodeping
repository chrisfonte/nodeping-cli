#!/usr/bin/env node

/**
 * NodePing CLI
 * A command-line interface for the NodePing monitoring API
 * 
 * Usage:
 *   nodeping checks list [--filter PATTERN] [--json]
 *   nodeping checks delete <id> [--force]
 *   nodeping checks delete --filter PATTERN [--dry-run] [--force]
 *   nodeping results <check-id> [--limit N]
 * 
 * Authentication:
 *   Reads API token from ~/.credentials/nodeping/api_token
 */

const https = require('https');
const fs = require('fs');
const path = require('path');
const os = require('os');

const VERSION = '1.3.0';
const API_BASE = 'api.nodeping.com';
const API_VERSION = '/api/1';

// ANSI color codes
const colors = {
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  dim: '\x1b[2m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  cyan: '\x1b[36m',
  gray: '\x1b[90m'
};

// Read API token from credentials file
function getApiToken() {
  const tokenPath = path.join(os.homedir(), '.credentials', 'nodeping', 'api_token');
  
  try {
    const token = fs.readFileSync(tokenPath, 'utf8').trim();
    if (!token) {
      throw new Error('Token file is empty');
    }
    return token;
  } catch (err) {
    console.error(`${colors.red}Error:${colors.reset} Could not read API token from ${tokenPath}`);
    console.error(`${colors.gray}Create the file with: mkdir -p ~/.credentials/nodeping && echo "YOUR_TOKEN" > ~/.credentials/nodeping/api_token${colors.reset}`);
    process.exit(1);
  }
}

// Make HTTP request to NodePing API
function apiRequest(method, endpoint, data = null, accountId = null) {
  return new Promise((resolve, reject) => {
    const token = getApiToken();
    
    let path = `${API_VERSION}${endpoint}${endpoint.includes('?') ? '&' : '?'}token=${token}`;
    if (accountId) {
      path += `&customerid=${accountId}`;
    }
    
    const options = {
      hostname: API_BASE,
      path: path,
      method: method,
      headers: {
        'Accept': 'application/json'
      }
    };
    
    if (data && method !== 'GET') {
      const postData = JSON.stringify({ json: data });
      options.headers['Content-Type'] = 'application/x-www-form-urlencoded';
      options.headers['Content-Length'] = Buffer.byteLength(postData);
    }
    
    const req = https.request(options, (res) => {
      let responseData = '';
      
      res.on('data', (chunk) => {
        responseData += chunk;
      });
      
      res.on('end', () => {
        try {
          const parsed = JSON.parse(responseData);
          
          if (res.statusCode >= 400) {
            const errorMsg = parsed.error || parsed.message || `HTTP ${res.statusCode}`;
            if (res.statusCode === 401) {
              reject(new Error(`Authentication failed: ${errorMsg}\nCheck your API token in ~/.credentials/nodeping/api_token`));
            } else if (res.statusCode === 403) {
              reject(new Error(`Permission denied: ${errorMsg}`));
            } else if (res.statusCode === 404) {
              reject(new Error(`Not found: ${errorMsg}`));
            } else {
              reject(new Error(errorMsg));
            }
          } else {
            resolve(parsed);
          }
        } catch (err) {
          if (res.statusCode >= 400) {
            reject(new Error(`HTTP ${res.statusCode}: ${responseData}`));
          } else {
            reject(new Error(`Failed to parse response: ${err.message}`));
          }
        }
      });
    });
    
    req.on('error', (err) => {
      if (err.code === 'ENOTFOUND') {
        reject(new Error('Network error: Could not reach NodePing API. Check your internet connection.'));
      } else if (err.code === 'ECONNREFUSED') {
        reject(new Error('Connection refused: NodePing API is unreachable.'));
      } else {
        reject(new Error(`Network error: ${err.message}`));
      }
    });
    
    if (data && method !== 'GET') {
      req.write(`json=${encodeURIComponent(JSON.stringify(data))}`);
    }
    
    req.end();
  });
}

function parseCliOptions(args, baseOptions = {}) {
  const optionSpecs = {
    '--filter': { key: 'filter', hasValue: true },
    '--dry-run': { key: 'dryRun', hasValue: false },
    '--force': { key: 'force', hasValue: false },
    '--json': { key: 'json', hasValue: false },
    '--limit': { key: 'limit', hasValue: true },
    '--account': { key: 'account', hasValue: true },
    '--desired': { key: 'desired', hasValue: true },
    '--current': { key: 'current', hasValue: true },
    '--normalize': { key: 'normalize', hasValue: false },
    '--label': { key: 'label', hasValue: true },
    '--type': { key: 'type', hasValue: true },
    '--target': { key: 'target', hasValue: true },
    '--interval': { key: 'interval', hasValue: true },
    '--enable': { key: 'enableFlag', hasValue: false },
    '--disable': { key: 'disableFlag', hasValue: false },
    '--threshold': { key: 'threshold', hasValue: true },
    '--sensitivity': { key: 'sensitivity', hasValue: true },
    '--method': { key: 'method', hasValue: true },
    '--status': { key: 'status', hasValue: true },
    '--port': { key: 'port', hasValue: true },
    '--param': { key: 'params', hasValue: true, multi: true }
  };

  const options = Object.assign({
    filter: null,
    dryRun: false,
    force: false,
    json: false,
    limit: 10,
    account: null,
    desired: null,
    current: null,
    normalize: false,
    label: null,
    type: null,
    target: null,
    interval: null,
    enableFlag: false,
    disableFlag: false,
    threshold: null,
    sensitivity: null,
    method: null,
    status: null,
    port: null,
    params: []
  }, baseOptions);

  const positionals = [];

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (!arg.startsWith('--')) {
      positionals.push(arg);
      continue;
    }

    const [flag, inlineValue] = arg.split('=', 2);
    const spec = optionSpecs[flag];
    if (!spec) {
      throw new Error(`Unknown option: ${flag}`);
    }

    if (spec.hasValue) {
      let value = inlineValue;
      if (value === undefined) {
        value = args[i + 1];
        if (value === undefined || value.startsWith('--')) {
          throw new Error(`Missing value for ${flag}`);
        }
        i++;
      }
      if (spec.multi) {
        options[spec.key].push(value);
      } else {
        options[spec.key] = value;
      }
    } else {
      options[spec.key] = true;
    }
  }

  return { options, positionals };
}

function normalizeEnable(value) {
  if (value === undefined || value === null) return null;
  if (typeof value === 'boolean') return value ? 'active' : 'inactive';
  if (typeof value === 'number') return value === 1 ? 'active' : 'inactive';
  const normalized = String(value).trim().toLowerCase();
  if (['active', 'enabled', 'enable', 'true', '1', 'on'].includes(normalized)) return 'active';
  if (['inactive', 'disabled', 'disable', 'false', '0', 'off'].includes(normalized)) return 'inactive';
  return null;
}

function parseParamPairs(paramList) {
  const params = {};
  if (!Array.isArray(paramList)) return params;
  for (const entry of paramList) {
    const idx = entry.indexOf('=');
    if (idx === -1) {
      throw new Error(`Invalid --param "${entry}". Use key=value.`);
    }
    const key = entry.slice(0, idx).trim();
    const value = entry.slice(idx + 1).trim();
    if (!key) {
      throw new Error(`Invalid --param "${entry}". Key is required.`);
    }
    params[key] = value;
  }
  return params;
}

function coerceUrlCandidate(value) {
  const trimmed = value.trim();
  if (!trimmed) return null;
  const hasScheme = /^[a-z][a-z0-9+.-]*:\/\//i.test(trimmed);
  const candidate = hasScheme ? trimmed : `https://${trimmed}`;
  try {
    return new URL(candidate);
  } catch {
    return null;
  }
}

function normalizeStreamPath(pathname) {
  let normalized = pathname.replace(/\/+$/, '');
  if (normalized.endsWith('/playlist.m3u8')) {
    normalized = normalized.slice(0, -'/playlist.m3u8'.length);
  }
  const suffixes = ['-icy', '-mp3'];
  for (const suffix of suffixes) {
    if (normalized.endsWith(suffix)) {
      normalized = normalized.slice(0, -suffix.length);
    }
  }
  normalized = normalized.replace(/\/+$/, '');
  return normalized || '/';
}

function normalizeHostname(hostname) {
  let normalized = hostname.toLowerCase();
  if (normalized.startsWith('edge.')) {
    normalized = `origin.${normalized.slice('edge.'.length)}`;
  }
  if (normalized.includes('.edge.')) {
    normalized = normalized.replace('.edge.', '.origin.');
  }
  return normalized;
}

function normalizeUrl(value) {
  const url = coerceUrlCandidate(value);
  if (!url) return value.trim();

  url.protocol = url.protocol.toLowerCase();
  url.hostname = normalizeHostname(url.hostname);

  if ((url.protocol === 'http:' && url.port === '80') || (url.protocol === 'https:' && url.port === '443')) {
    url.port = '';
  }

  url.pathname = normalizeStreamPath(url.pathname);
  url.hash = '';

  const normalized = `${url.protocol}//${url.host}${url.pathname}${url.search}`;
  return normalized.replace(/\/+$/, '');
}

function normalizeTarget(target) {
  if (!target) return target;
  return normalizeUrl(String(target));
}

function buildCheckPayloadFromOptions(options, isCreate = false) {
  const payload = {};
  if (options.label) payload.label = options.label;
  if (options.type) payload.type = String(options.type).toUpperCase();
  if (options.interval) payload.interval = parseInt(options.interval, 10);

  const enableValue = options.enableFlag ? 'active' : options.disableFlag ? 'inactive' : null;
  if (enableValue) payload.enable = enableValue;

  const params = {};
  if (options.target) params.target = options.target;
  if (options.threshold !== null && options.threshold !== undefined) params.threshold = Number(options.threshold);
  if (options.sensitivity !== null && options.sensitivity !== undefined) params.sensitivity = Number(options.sensitivity);
  if (options.method) params.method = options.method.toUpperCase();
  if (options.status) params.status = options.status;
  if (options.port) params.port = Number(options.port);

  const extraParams = parseParamPairs(options.params);
  Object.assign(params, extraParams);

  if (Object.keys(params).length > 0) {
    payload.parameters = params;
  }

  if (isCreate) {
    if (!payload.label) throw new Error('Missing required --label for check creation');
    if (!payload.type) throw new Error('Missing required --type for check creation');
    if (!payload.parameters || !payload.parameters.target) {
      throw new Error('Missing required --target for check creation');
    }
  }

  return payload;
}

// List all checks or filter by pattern
async function listChecks(options = {}) {
  const checks = await apiRequest('GET', '/checks', null, options.account);
  
  let checkList = Object.entries(checks).map(([id, check]) => ({
    id,
    ...check
  }));
  
  // Apply filter if provided
  if (options.filter) {
    const pattern = new RegExp(options.filter, 'i');
    checkList = checkList.filter(check => 
      pattern.test(check.label) || 
      pattern.test(check.parameters?.target || '') ||
      pattern.test(check.type)
    );
  }
  
  if (options.json) {
    console.log(JSON.stringify(checkList, null, 2));
    return checkList;
  }
  
  // Human-readable output
  const accountNote = options.account ? ` (Account: ${options.account})` : '';
  console.log(`${colors.bright}${checkList.length} check(s) found${accountNote}${colors.reset}\n`);
  
  checkList.forEach(check => {
    const status = check.state === 1 ? `${colors.green}PASS${colors.reset}` : `${colors.red}FAIL${colors.reset}`;
    const enabled = check.enable === 'active' ? `${colors.green}enabled${colors.reset}` : `${colors.gray}disabled${colors.reset}`;
    
    console.log(`${colors.cyan}${check.id}${colors.reset}`);
    console.log(`  Label: ${colors.bright}${check.label}${colors.reset}`);
    console.log(`  Type: ${check.type}`);
    if (check.parameters?.target) {
      console.log(`  Target: ${check.parameters.target}`);
    }
    console.log(`  Status: ${status} | ${enabled}`);
    console.log(`  Interval: ${check.interval} min`);
    console.log('');
  });
  
  return checkList;
}

async function createCheck(options = {}) {
  const payload = buildCheckPayloadFromOptions(options, true);
  const result = await apiRequest('POST', '/checks', payload, options.account);
  return { payload, result };
}

async function updateCheck(checkId, options = {}) {
  const payload = buildCheckPayloadFromOptions(options, false);
  if (Object.keys(payload).length === 0) {
    throw new Error('No update fields provided. Use --label, --interval, --enable/--disable, or parameter flags.');
  }
  const result = await apiRequest('PUT', `/checks/${checkId}`, payload, options.account);
  return { payload, result };
}

async function renameCheck(checkId, newLabel, options = {}) {
  const payload = { label: newLabel };
  const result = await apiRequest('PUT', `/checks/${checkId}`, payload, options.account);
  return { payload, result };
}

async function setCheckStatus(checkId, enableValue, options = {}) {
  const payload = { enable: enableValue };
  const result = await apiRequest('PUT', `/checks/${checkId}`, payload, options.account);
  return { payload, result };
}

// Delete a single check
async function deleteCheck(checkId, force = false, account = null) {
  if (!force) {
    console.error(`${colors.yellow}Warning:${colors.reset} Use --force to confirm deletion`);
    return false;
  }
  
  try {
    const result = await apiRequest('DELETE', `/checks/${checkId}`, null, account);
    
    if (result.ok) {
      console.log(`${colors.green}✓${colors.reset} Deleted check: ${checkId}`);
      return true;
    } else {
      console.error(`${colors.red}✗${colors.reset} Failed to delete: ${checkId}`);
      return false;
    }
  } catch (err) {
    console.error(`${colors.red}Error:${colors.reset} ${err.message}`);
    return false;
  }
}

// Bulk delete checks by filter pattern
async function bulkDelete(filter, options = {}) {
  const checks = await listChecks({ filter, json: true, account: options.account });
  
  if (checks.length === 0) {
    console.log(`${colors.yellow}No checks found matching filter: ${filter}${colors.reset}`);
    return;
  }
  
  console.log(`${colors.bright}Found ${checks.length} check(s) matching "${filter}"${colors.reset}\n`);
  
  // Show what will be deleted
  checks.forEach(check => {
    console.log(`  ${colors.cyan}${check.id}${colors.reset} - ${check.label} (${check.type})`);
  });
  
  console.log('');
  
  if (options.dryRun) {
    console.log(`${colors.yellow}DRY RUN:${colors.reset} Would delete ${checks.length} check(s)`);
    console.log(`${colors.gray}Remove --dry-run and add --force to execute deletion${colors.reset}`);
    return;
  }
  
  if (!options.force) {
    console.error(`${colors.red}Error:${colors.reset} Add --force to confirm bulk deletion of ${checks.length} check(s)`);
    process.exit(1);
  }
  
  // Perform deletions
  let deleted = 0;
  let failed = 0;
  
  for (const check of checks) {
    const success = await deleteCheck(check.id, true, options.account);
    if (success) {
      deleted++;
    } else {
      failed++;
    }
  }
  
  console.log('');
  console.log(`${colors.bright}Summary:${colors.reset}`);
  console.log(`  ${colors.green}Deleted: ${deleted}${colors.reset}`);
  if (failed > 0) {
    console.log(`  ${colors.red}Failed: ${failed}${colors.reset}`);
  }
}

// List all subaccounts
async function listAccounts(options = {}) {
  try {
    const accounts = await apiRequest('GET', '/accounts');
    
    if (options.json) {
      console.log(JSON.stringify(accounts, null, 2));
      return;
    }
    
    // Human-readable output
    const accountList = Object.entries(accounts).map(([id, account]) => ({
      id,
      ...account
    }));
    
    console.log(`${colors.bright}${accountList.length} account(s) found${colors.reset}\n`);
    
    accountList.forEach(account => {
      const status = account.status === 'Active' ? `${colors.green}Active${colors.reset}` : `${colors.gray}${account.status}${colors.reset}`;
      
      console.log(`${colors.cyan}${account.id}${colors.reset}`);
      console.log(`  Name: ${colors.bright}${account.name || 'Unnamed'}${colors.reset}`);
      console.log(`  Status: ${status}`);
      if (account.parent) {
        console.log(`  Parent Account: ${account.parent}`);
      }
      console.log('');
    });
  } catch (err) {
    console.error(`${colors.red}Error:${colors.reset} ${err.message}`);
    process.exit(1);
  }
}

// Get results for a check
async function getResults(checkId, options = {}) {
  const limit = options.limit || 10;
  const results = await apiRequest('GET', `/results/${checkId}?limit=${limit}`, null, options.account);
  
  if (options.json) {
    console.log(JSON.stringify(results, null, 2));
    return;
  }
  
  // Human-readable output
  const resultList = Array.isArray(results) ? results : [results];
  
  console.log(`${colors.bright}Last ${resultList.length} result(s) for ${checkId}${colors.reset}\n`);
  
  resultList.forEach(result => {
    // Handle nested doc structure from API
    const doc = result.doc || result;
    const status = doc.su ? `${colors.green}SUCCESS${colors.reset}` : `${colors.red}FAILURE${colors.reset}`;
    const timestamp = doc.s || doc.t;
    const date = new Date(timestamp);
    
    console.log(`${colors.cyan}${date.toISOString()}${colors.reset}`);
    console.log(`  Status: ${status}`);
    console.log(`  Runtime: ${doc.rt}ms`);
    if (doc.m) {
      console.log(`  Message: ${doc.m}`);
    }
    if (doc.sc) {
      console.log(`  Status Code: ${doc.sc}`);
    }
    console.log('');
  });
}

function readJsonFile(filePath) {
  const raw = fs.readFileSync(filePath, 'utf8');
  return JSON.parse(raw);
}

function coerceCheckShape(check) {
  const normalized = Object.assign({}, check);
  if (!normalized.parameters) {
    normalized.parameters = {};
  }
  if (normalized.target !== undefined && normalized.parameters.target === undefined) {
    normalized.parameters.target = normalized.target;
  }
  if (normalized.threshold !== undefined && normalized.parameters.threshold === undefined) {
    normalized.parameters.threshold = normalized.threshold;
  }
  if (normalized.sensitivity !== undefined && normalized.parameters.sensitivity === undefined) {
    normalized.parameters.sensitivity = normalized.sensitivity;
  }
  if (normalized.method !== undefined && normalized.parameters.method === undefined) {
    normalized.parameters.method = normalized.method;
  }
  if (normalized.status !== undefined && normalized.parameters.status === undefined) {
    normalized.parameters.status = normalized.status;
  }
  if (normalized.port !== undefined && normalized.parameters.port === undefined) {
    normalized.parameters.port = normalized.port;
  }
  return normalized;
}

function toCheckArray(data) {
  if (!data) return [];
  if (Array.isArray(data)) return data;
  if (Array.isArray(data.checks)) return data.checks;
  if (typeof data === 'object') {
    return Object.entries(data).map(([id, check]) => ({ id, ...check }));
  }
  return [];
}

function normalizeComparableCheck(check, normalizeTargets) {
  const base = coerceCheckShape(check);
  const parameters = Object.assign({}, base.parameters);
  if (normalizeTargets && parameters.target) {
    parameters.target = normalizeTarget(parameters.target);
  }
  return {
    id: base.id,
    label: base.label ? String(base.label).trim() : '',
    type: base.type ? String(base.type).toUpperCase() : '',
    interval: base.interval !== undefined ? Number(base.interval) : null,
    enable: normalizeEnable(base.enable ?? base.enabled ?? (base.disabled === true ? false : undefined)),
    parameters
  };
}

function buildCheckKey(check, normalizeTargets) {
  const normalized = normalizeComparableCheck(check, normalizeTargets);
  const label = normalized.label.toLowerCase();
  const type = normalized.type;
  const target = normalized.parameters?.target ? String(normalized.parameters.target).toLowerCase() : '';
  return `${type}::${label}::${target}`;
}

function extractDesiredFields(check, normalizeTargets) {
  const base = coerceCheckShape(check);
  const fields = {};

  if (Object.prototype.hasOwnProperty.call(base, 'label')) {
    fields.label = base.label;
  }
  if (Object.prototype.hasOwnProperty.call(base, 'type')) {
    fields.type = base.type ? String(base.type).toUpperCase() : base.type;
  }
  if (Object.prototype.hasOwnProperty.call(base, 'interval')) {
    fields.interval = Number(base.interval);
  }

  const enableValue = normalizeEnable(base.enable ?? base.enabled ?? (base.disabled === true ? false : undefined));
  if (enableValue !== null) {
    fields.enable = enableValue;
  } else if (
    Object.prototype.hasOwnProperty.call(base, 'enable') ||
    Object.prototype.hasOwnProperty.call(base, 'enabled') ||
    Object.prototype.hasOwnProperty.call(base, 'disabled')
  ) {
    fields.enable = enableValue;
  }

  const params = {};
  for (const key of ['target', 'threshold', 'sensitivity', 'method', 'status', 'port']) {
    if (Object.prototype.hasOwnProperty.call(base.parameters, key)) {
      let value = base.parameters[key];
      if (key === 'target' && normalizeTargets) {
        value = normalizeTarget(value);
      }
      if (key === 'method') {
        value = String(value).toUpperCase();
      }
      params[key] = value;
    }
  }
  if (Object.keys(params).length > 0) {
    fields.parameters = params;
  }

  return fields;
}

function diffChecks(desiredFields, currentComparable) {
  const changes = {};

  if ('label' in desiredFields && desiredFields.label !== currentComparable.label) {
    changes.label = desiredFields.label;
  }
  if ('type' in desiredFields && desiredFields.type !== currentComparable.type) {
    changes.type = desiredFields.type;
  }
  if ('interval' in desiredFields && desiredFields.interval !== currentComparable.interval) {
    changes.interval = desiredFields.interval;
  }
  if ('enable' in desiredFields && desiredFields.enable !== currentComparable.enable) {
    changes.enable = desiredFields.enable;
  }

  if (desiredFields.parameters) {
    const paramChanges = {};
    for (const [key, value] of Object.entries(desiredFields.parameters)) {
      const currentValue = currentComparable.parameters ? currentComparable.parameters[key] : undefined;
      if (value !== currentValue) {
        paramChanges[key] = value;
      }
    }
    if (Object.keys(paramChanges).length > 0) {
      changes.parameters = paramChanges;
    }
  }

  return changes;
}

function buildPayloadFromDesiredCheck(check, normalizeTargets) {
  const desired = extractDesiredFields(check, normalizeTargets);
  const payload = {};
  if ('label' in desired) payload.label = desired.label;
  if ('type' in desired) payload.type = desired.type;
  if ('interval' in desired) payload.interval = desired.interval;
  if ('enable' in desired && desired.enable !== null) payload.enable = desired.enable;
  if (desired.parameters) payload.parameters = desired.parameters;

  if (!payload.label || !payload.type || !payload.parameters || !payload.parameters.target) {
    throw new Error('Desired check entries must include label, type, and parameters.target');
  }

  return payload;
}

async function loadChecksForSync(options) {
  if (options.current) {
    return toCheckArray(readJsonFile(options.current));
  }
  return await listChecks({ json: true, account: options.account });
}

async function planSync(options) {
  if (!options.desired) {
    throw new Error('Missing --desired <file>');
  }

  const desiredRaw = readJsonFile(options.desired);
  const desiredChecks = toCheckArray(desiredRaw).map(coerceCheckShape);
  const currentChecks = await loadChecksForSync(options);

  const currentById = new Map();
  const currentByKey = new Map();

  currentChecks.forEach((check) => {
    if (check.id) currentById.set(check.id, check);
    const key = buildCheckKey(check, options.normalize);
    if (key && !currentByKey.has(key)) {
      currentByKey.set(key, check);
    }
  });

  const plan = {
    create: [],
    update: [],
    disable: [],
    delete: []
  };

  const matchedCurrentIds = new Set();

  desiredChecks.forEach((desired) => {
    if (!desired.label || !desired.type || !desired.parameters?.target) {
      throw new Error('Each desired check must include label, type, and parameters.target');
    }
    const desiredId = desired.id;
    let current = null;
    if (desiredId && currentById.has(desiredId)) {
      current = currentById.get(desiredId);
    } else {
      const key = buildCheckKey(desired, options.normalize);
      if (currentByKey.has(key)) {
        current = currentByKey.get(key);
      }
    }

    if (!current) {
      plan.create.push({ desired });
      return;
    }

    matchedCurrentIds.add(current.id);
    const desiredFields = extractDesiredFields(desired, options.normalize);
    const currentComparable = normalizeComparableCheck(current, options.normalize);
    const changes = diffChecks(desiredFields, currentComparable);

    if ('enable' in desiredFields && desiredFields.enable === 'inactive' && currentComparable.enable !== 'inactive') {
      if (changes.enable === 'inactive') {
        delete changes.enable;
      }
      plan.disable.push({ id: current.id, label: current.label });
    }

    if (Object.keys(changes).length > 0) {
      plan.update.push({ id: current.id, label: current.label, changes, desired });
    }
  });

  currentChecks.forEach((current) => {
    if (current.id && !matchedCurrentIds.has(current.id)) {
      plan.delete.push({ id: current.id, label: current.label, type: current.type });
    }
  });

  const sortByLabel = (a, b) => (String(a.label || '').localeCompare(String(b.label || '')));
  plan.create.sort((a, b) => sortByLabel(a.desired, b.desired));
  plan.update.sort(sortByLabel);
  plan.disable.sort(sortByLabel);
  plan.delete.sort(sortByLabel);

  return plan;
}

async function applySync(options) {
  if (!options.force) {
    throw new Error('Add --force to apply changes');
  }

  const plan = await planSync(options);
  const results = { created: [], updated: [], disabled: [], deleted: [] };

  for (const entry of plan.create) {
    const payload = buildPayloadFromDesiredCheck(entry.desired, options.normalize);
    const result = await apiRequest('POST', '/checks', payload, options.account);
    results.created.push({ payload, result });
  }

  for (const entry of plan.update) {
    const payload = {};
    if (entry.changes.label) payload.label = entry.changes.label;
    if (entry.changes.type) payload.type = entry.changes.type;
    if (entry.changes.interval !== undefined) payload.interval = entry.changes.interval;
    if (entry.changes.enable) payload.enable = entry.changes.enable;
    if (entry.changes.parameters) payload.parameters = entry.changes.parameters;

    const result = await apiRequest('PUT', `/checks/${entry.id}`, payload, options.account);
    results.updated.push({ id: entry.id, payload, result });
  }

  for (const entry of plan.disable) {
    const result = await apiRequest('PUT', `/checks/${entry.id}`, { enable: 'inactive' }, options.account);
    results.disabled.push({ id: entry.id, result });
  }

  for (const entry of plan.delete) {
    const result = await apiRequest('DELETE', `/checks/${entry.id}`, null, options.account);
    results.deleted.push({ id: entry.id, result });
  }

  return { plan, results };
}

