// Main CLI router
async function main() {
  const args = process.argv.slice(2);
  const command = args[0];
  
  if (args.length === 0) {
    printUsage();
    process.exit(0);
  }
  
  if (args.includes('--version') || args.includes('-v')) {
    console.log(`nodeping v${VERSION}`);
    process.exit(0);
  }

  if ((args.includes('--help') || args.includes('-h')) && command !== 'tui') {
    printUsage();
    process.exit(0);
  }
  const subcommand = args[1];
  
  try {
    if (command === 'checks' && subcommand === 'list') {
      const { options } = parseCliOptions(args.slice(2));
      await listChecks(options);
    } else if (command === 'checks' && subcommand === 'delete') {
      const { options, positionals } = parseCliOptions(args.slice(2));
      const checkId = positionals[0];

      if (options.filter) {
        await bulkDelete(options.filter, options);
      } else if (checkId && !checkId.startsWith('--')) {
        await deleteCheck(checkId, options.force, options.account);
      } else {
        console.error(`${colors.red}Error:${colors.reset} Specify a check ID or use --filter for bulk deletion`);
        process.exit(1);
      }
    } else if (command === 'checks' && subcommand === 'create') {
      const { options } = parseCliOptions(args.slice(2));
      const result = await createCheck(options);
      if (options.json) {
        console.log(JSON.stringify(result, null, 2));
      } else {
        console.log(`${colors.green}✓${colors.reset} Created check`);
        console.log(`  Label: ${result.payload.label}`);
        console.log(`  Type: ${result.payload.type}`);
        if (result.payload.parameters?.target) {
          console.log(`  Target: ${result.payload.parameters.target}`);
        }
      }
    } else if (command === 'checks' && subcommand === 'update') {
      const { options, positionals } = parseCliOptions(args.slice(2));
      const checkId = positionals[0];
      if (!checkId) {
        console.error(`${colors.red}Error:${colors.reset} Specify a check ID to update`);
        process.exit(1);
      }
      const result = await updateCheck(checkId, options);
      if (options.json) {
        console.log(JSON.stringify({ id: checkId, ...result }, null, 2));
      } else {
        console.log(`${colors.green}✓${colors.reset} Updated check: ${checkId}`);
      }
    } else if (command === 'checks' && subcommand === 'rename') {
      const { options, positionals } = parseCliOptions(args.slice(2));
      const checkId = positionals[0];
      const newLabel = positionals[1];
      if (!checkId || !newLabel) {
        console.error(`${colors.red}Error:${colors.reset} Usage: nodeping checks rename <id> <newLabel>`);
        process.exit(1);
      }
      const result = await renameCheck(checkId, newLabel, options);
      if (options.json) {
        console.log(JSON.stringify({ id: checkId, ...result }, null, 2));
      } else {
        console.log(`${colors.green}✓${colors.reset} Renamed check: ${checkId}`);
        console.log(`  New label: ${newLabel}`);
      }
    } else if (command === 'checks' && subcommand === 'enable') {
      const { options, positionals } = parseCliOptions(args.slice(2));
      const checkId = positionals[0];
      if (!checkId) {
        console.error(`${colors.red}Error:${colors.reset} Specify a check ID to enable`);
        process.exit(1);
      }
      const result = await setCheckStatus(checkId, 'active', options);
      if (options.json) {
        console.log(JSON.stringify({ id: checkId, ...result }, null, 2));
      } else {
        console.log(`${colors.green}✓${colors.reset} Enabled check: ${checkId}`);
      }
    } else if (command === 'checks' && subcommand === 'disable') {
      const { options, positionals } = parseCliOptions(args.slice(2));
      const checkId = positionals[0];
      if (!checkId) {
        console.error(`${colors.red}Error:${colors.reset} Specify a check ID to disable`);
        process.exit(1);
      }
      const result = await setCheckStatus(checkId, 'inactive', options);
      if (options.json) {
        console.log(JSON.stringify({ id: checkId, ...result }, null, 2));
      } else {
        console.log(`${colors.green}✓${colors.reset} Disabled check: ${checkId}`);
      }
    } else if (command === 'accounts' && subcommand === 'list') {
      const { options } = parseCliOptions(args.slice(2));
      await listAccounts(options);
    } else if (command === 'results') {
      const { options, positionals } = parseCliOptions(args.slice(1));
      const checkId = positionals[0];
      if (!checkId) {
        console.error(`${colors.red}Error:${colors.reset} Specify a check ID`);
        process.exit(1);
      }
      await getResults(checkId, options);
    } else if (command === 'sync' && (subcommand === 'plan' || subcommand === 'apply')) {
      const { options } = parseCliOptions(args.slice(2));
      if (subcommand === 'plan') {
        const plan = await planSync(options);
        if (options.json) {
          console.log(JSON.stringify({
            summary: {
              create: plan.create.length,
              update: plan.update.length,
              disable: plan.disable.length,
              delete: plan.delete.length
            },
            plan
          }, null, 2));
        } else {
          console.log(`${colors.bright}Sync plan${colors.reset}`);
          console.log(`  Create: ${plan.create.length}`);
          console.log(`  Update: ${plan.update.length}`);
          console.log(`  Disable: ${plan.disable.length}`);
          console.log(`  Delete: ${plan.delete.length}\n`);

          if (plan.create.length) {
            console.log(`${colors.cyan}Create${colors.reset}`);
            plan.create.forEach(entry => {
              console.log(`  ${entry.desired.label} (${entry.desired.type})`);
            });
            console.log('');
          }

          if (plan.update.length) {
            console.log(`${colors.cyan}Update${colors.reset}`);
            plan.update.forEach(entry => {
              const fields = Object.keys(entry.changes).join(', ');
              console.log(`  ${entry.label} (${entry.id}) -> ${fields}`);
            });
            console.log('');
          }

          if (plan.disable.length) {
            console.log(`${colors.cyan}Disable${colors.reset}`);
            plan.disable.forEach(entry => {
              console.log(`  ${entry.label} (${entry.id})`);
            });
            console.log('');
          }

          if (plan.delete.length) {
            console.log(`${colors.cyan}Delete${colors.reset}`);
            plan.delete.forEach(entry => {
              console.log(`  ${entry.label} (${entry.id})`);
            });
            console.log('');
          }
        }
      } else {
        const result = await applySync(options);
        if (options.json) {
          console.log(JSON.stringify(result, null, 2));
        } else {
          const summary = result.plan;
          console.log(`${colors.bright}Sync applied${colors.reset}`);
          console.log(`  Created: ${summary.create.length}`);
          console.log(`  Updated: ${summary.update.length}`);
          console.log(`  Disabled: ${summary.disable.length}`);
          console.log(`  Deleted: ${summary.delete.length}`);
        }
      }
    } else if (command === 'tui') {
      if (args.includes('--help') || args.includes('-h')) {
        printTuiHelp();
        process.exit(0);
      }
      const { runTui } = require('./src/tui');
      await runTui(args.slice(1));
    } else {
      console.error(`${colors.red}Error:${colors.reset} Unknown command: ${command} ${subcommand || ''}`);
      console.error(`Run ${colors.cyan}nodeping --help${colors.reset} for usage information`);
      process.exit(1);
    }
  } catch (err) {
    console.error(`${colors.red}Error:${colors.reset} ${err.message}`);
    process.exit(1);
  }
}

// Run the CLI
if (require.main === module) {
  main();
}

